[Unit]
Description=OpenClaw gateway — %%OC_NAME%%
After=network-online.target
Wants=network-online.target

[Container]
Image=ghcr.io/openclaw/openclaw:slim
ContainerName=%%OC_NAME%%
UserNS=keep-id
User=%%OC_UID%%:%%OC_GID%%
Network=host
Volume=%%OC_DATA%%:/home/node/.openclaw:Z
EnvironmentFile=%%OC_DATA%%/.env
Environment=HOME=/home/node
Environment=TERM=xterm-256color
AddDevice=nvidia.com/gpu=0
NoNewPrivileges=true
Pull=never
Exec=node dist/index.js gateway --bind lan --port %%OC_PORT%%

[Service]
TimeoutStartSec=300
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
